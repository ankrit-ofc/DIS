# ─── API ─────────────────────────────────────────────
# REQUIRED. Base URL for the distro-api service, INCLUDING the /api prefix.
# Local: http://127.0.0.1:3001/api   Prod example: https://api.distronepal.com/api
NEXT_PUBLIC_API_URL="http://127.0.0.1:3001/api"

# ─── Google ──────────────────────────────────────────
# REQUIRED for the "Sign in with Google" button on /login.
# Must match GOOGLE_CLIENT_ID in distro-api.
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# REQUIRED for the address-picker map (buyer checkout) and the admin order-map view.
# Restrict the key by HTTP referrer in Google Cloud Console before going to prod.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-browser-key"

# ─── Notes ───────────────────────────────────────────
# - All NEXT_PUBLIC_* vars are bundled into the client JS — never put secrets here.
# - Local dev: copy this to .env and fill in real values.
# - Vercel: set these in Project Settings → Environment Variables.
#   NEXT_PUBLIC_API_URL must be updated AFTER the Railway API deploys, since the URL
#   is only known after Railway provisions the service.
