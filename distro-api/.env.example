# ─── Database ────────────────────────────────────────
# REQUIRED. MySQL connection string. Railway will auto-inject this when a MySQL
# plugin is attached to the service. For local dev: XAMPP defaults below.
DATABASE_URL="mysql://root:@localhost:3306/distro"

# ─── Auth ────────────────────────────────────────────
# REQUIRED. 32-byte hex string. Generate with: openssl rand -hex 32
JWT_SECRET="replace-with-32-byte-hex-string"

# REQUIRED in production only. Initial admin password set during `npm run db:seed`.
# In dev, falls back to "admin123" if unset.
ADMIN_SEED_PASSWORD="change-me-strong-password"
# Optional. Phone for the seeded admin. Defaults to 9800000000.
ADMIN_SEED_PHONE="9800000000"

# ─── App config ──────────────────────────────────────
# REQUIRED. "production" on Railway, "development" locally.
NODE_ENV="development"
# Optional. Port the API binds to. Defaults to 3001.
API_PORT=3001
# REQUIRED in production. Comma-separated list of allowed origins for CORS.
# Local: http://localhost:3000   Prod example: https://distronepal.com,https://distro.vercel.app
CORS_ORIGIN="http://localhost:3000"
# Optional. Local disk path for uploaded files. Move to Cloudflare R2 for production
# (Railway disks are ephemeral — files are lost between deploys).
UPLOAD_DIR="./uploads"

# ─── SMS (Sparrow SMS Nepal) ─────────────────────────
# Set "false" to skip outbound SMS calls (logs only). Set "true" or leave unset in prod.
SMS_ENABLED="false"
# Optional. Set to "1" to log payloads without calling Sparrow (overrides SMS_ENABLED).
SMS_DRY_RUN=""
SPARROW_SMS_TOKEN="your-sparrow-token-here"
SPARROW_SMS_FROM="9800000000"

# ─── Email (Resend) ──────────────────────────────────
# Set "false" to skip outbound email calls (logs only). Set "true" in prod.
EMAIL_ENABLED="false"
RESEND_API_KEY="re_your-resend-api-key"
# MUST be a domain verified in the Resend dashboard.
RESEND_FROM="DISTRO Nepal <orders@distronepal.com>"
# Optional. If set in non-prod, all outbound mail is rerouted to this address.
RESEND_TEST_TO=""
# Recipient for new-order admin notifications.
ADMIN_EMAIL="admin@distronepal.com"

# ─── Google OAuth ────────────────────────────────────
# Used to verify Google ID tokens from the "Sign in with Google" button.
# Must match NEXT_PUBLIC_GOOGLE_CLIENT_ID in distro-web.
GOOGLE_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"

# ─── Payments — eSewa ────────────────────────────────
# Optional during dev. Required if eSewa checkout is enabled in prod.
ESEWA_MERCHANT_CODE=""
ESEWA_SECRET_KEY=""
ESEWA_SUCCESS_URL=""
ESEWA_FAILURE_URL=""

# ─── Payments — Khalti ───────────────────────────────
# Optional during dev. Required if Khalti checkout is enabled in prod.
KHALTI_SECRET_KEY=""
KHALTI_RETURN_URL=""
KHALTI_WEBSITE_URL=""

# ─── WhatsApp (currently inactive) ───────────────────
# Optional. If both are set, notifications try WhatsApp first then fall back to SMS.
WHATSAPP_PHONE_ID=""
WHATSAPP_TOKEN=""

# ─── Invoice / Company details (printed on PDF VAT bills) ─
COMPANY_NAME="DISTRO Nepal Pvt Ltd"
COMPANY_ADDRESS="Kathmandu Valley, Nepal"
COMPANY_PAN=""
COMPANY_CONTACT="support@distro.com.np"
VAT_RATE="0.13"

# ─── Seed control ────────────────────────────────────
# Optional. Set to "1" to allow `prisma seed` to wipe + reseed in production.
# Leave unset on Railway unless you explicitly want to reset prod data.
SEED_RESET=""

# ─── Notes ───────────────────────────────────────────
# - Never commit a real .env file. This .env.example is the only one in git.
# - Local dev: copy this to .env and fill in real values.
# - Railway: set these in the Railway service dashboard. DATABASE_URL is auto-set
#   when you attach a MySQL plugin to the service.
# - Required: DATABASE_URL, JWT_SECRET, NODE_ENV, CORS_ORIGIN
#   plus ADMIN_SEED_PASSWORD when seeding in production
# - Optional: WhatsApp, eSewa, Khalti, Google OAuth (graceful degrade if missing)
